{
  "manifest_version": 3,
  "name": "FB Comment Scraper - ตัวดึงคอมเมนต์เฟซบุ๊ก",
  "version": "1.3",
  "description": "ดึงข้อมูลความคิดเห็นในกลุ่มเฟซบุ๊กส่วนตัว รวมถึงรูปภาพแนบและคอมเมนต์ย่อย แสดงผลผ่าน Chrome Side Panel และส่งออกไฟล์ CSV/JSON",
  "permissions": [
    "activeTab",
    "scripting",
    "downloads",
    "sidePanel",
    "storage"
  ],
  "host_permissions": [
    "*://*.facebook.com/*",
    "*://*.fb.com/*"
  ],
  "icons": {
    "16": "image/logo_1.png",
    "32": "image/logo_1.png",
    "48": "image/logo_1.png",
    "128": "image/logo_1.png"
  },
  "action": {
    "default_title": "เปิดแผงควบคุมดึงคอมเมนต์",
    "default_icon": {
      "16": "image/logo_1.png",
      "32": "image/logo_1.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.facebook.com/*",
        "*://*.fb.com/*"
      ],
      "js": [
        "scraper-core.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
